# =====================================================
# 🎉 BIRTHDAY BLOOM v2.0 - ENVIRONMENT VARIABLES GUIDE
# =====================================================
# Copy this file to .env.local and fill in your values
# All variables are optional - defaults will be used if not provided

# =====================================================
# BASIC INFORMATION - Essential for personalization
# =====================================================

# Birthday person's name
# Example: VITE_BIRTHDAY_NAME=Sarah
VITE_BIRTHDAY_NAME=Birthday Person

# Age of the birthday person (used for mood detection)
# Range: 1-120
VITE_BIRTHDAY_AGE=18

# Gender (affects message tone and template selection)
# Options: "male" | "female" | "other"
VITE_BIRTHDAY_GENDER=female

# Relationship to the birthday person
# Options: "partner" | "friend" | "family" | "colleague" | "mentor"
VITE_BIRTHDAY_RELATIONSHIP=friend

# =====================================================
# CUSTOMIZATION - Personalize the experience
# =====================================================

# Custom greeting message
VITE_BIRTHDAY_CUSTOM_MESSAGE=Have the most amazing birthday ever!

# Who is sending the birthday wish
VITE_BIRTHDAY_WISHER_NAME=Alex

# Optional letter heading and custom letter body
VITE_BIRTHDAY_LETTER_TITLE=To My Favorite Person 💖
VITE_BIRTHDAY_LETTER_OVERRIDE=Happy birthday, my love ❤️🎂

17/5 مش مجرد تاريخ عادي…
ده اليوم اللي الدنيا نورت فيه أكتر، اليوم اللي ربنا بعت فيه أجمل وأحن بنت شافتها عيني.
اليوم اللي اتولدت فيه البنت اللي غيرت حياتي كلها من غير ما تحس… بعيونها الخضرا اللي تاخد القلب من أول نظرة، وبروحها الهادية اللي مجرد وجودها يطمن أي حد حواليها.

بقالى 3 سنين مستني اللحظة دي…
مستني أقولك كلام يليق بيكي، وكل مرة كنت بسكت، مش عشان معنديش كلام… بالعكس، عشان اللي جوايا أكبر من أي كلام يتكتب.

بس النهارده لازم أقولك…

أنا بحبك يا رندا…
بحبك يا رورو…
بحبك يا رنوده… ❤️

بحب كل تفصيلة فيكي…
ضحكتك اللي بتخليني أنسى الدنيا، طريقتك في الكلام، عفويتك، حيائك، وحنيتك اللي بتحسسني دايمًا إني مش لوحدي.
بحب قلبك النضيف اللي بقى نادر جدًا اليومين دول، وبحب إنك بقيتي الأمان والراحة والحاجة الوحيدة اللي لما بفكر فيها بحس إن الدنيا لسه بخير.

وفاكرة أول مرة اتكلمنا؟
لما سألتك على الامتحان وقولتيلي “صفحة 173”… يمكن كانت كلمة عادية جدًا، بس بالنسبة لي كانت بداية كل حاجة حلوة حصلتلي بعد كده.
ومن يومها وانتي ماخرجتيش من قلبي لحظة واحدة.

وفاكر 13/9/2023…
اليوم اللي اتأكدت فيه إني بحبك بجد، حب من غير خوف ولا تردد، حب كل يوم بيكبر أكتر.

انتي غيرتيني من غير ما تحسي…
خليتيني أهدى، أحسن، وأقرب لنفسي.
وجودك فرق معايا بطريقة مستحيل أوصفها، وبقي لأي يوم طعم تاني لمجرد إنك فيه.

ووعد مني ليكي…
مهما حصل، عمري ما هسيبك، ولا هفرط فيكي، ولا هزهق منك.
هفضل جنبك دايمًا، الشخص اللي يسمعك قبل ما تتكلمي، ويحاول يفرحك حتى لو على حساب نفسه.

ووعد تاني خليه في بالك كويس 💍
عيد ميلادك اللي بعد اللي جاي، دبلتي هتكون في إيدك… ووعدي ليكي من قلبي إني أحقق اليوم ده.

أنا بجد ممتن إنك موجودة في حياتي…
ممتن لكل لحظة، لكل كلمة، لكل ذكرى صغيرة بينا من أول “صفحة 173” لحد دلوقتي.

كل سنة وانتي أجمل بنت شافتها عيني…
كل سنة وانتي أقرب إنسانة لقلبي…
كل سنة وانتي النور اللي في حياتي…
وكل سنة وأنا محظوظ بيكي.

بحبك… وهفضل أحبك أكتر كل يوم ❤️

# Favorite color (hex code)
VITE_BIRTHDAY_COLOR=#FF6B6B

# Comma-separated interests/hobbies
VITE_BIRTHDAY_INTERESTS=Gaming,Music,Travel

# Favorite emojis (comma-separated, up to 8)
VITE_FAVORITE_EMOJIS=🎉,✨,🎊,🎈,🥳

# =====================================================
# MEDIA ASSETS - Photos and Audio
# =====================================================

# Photo URLs (JPEG, PNG, WebP supported)
VITE_PHOTO_1=https://images.unsplash.com/photo-1530103043960-ef38714abb15?w=800
VITE_PHOTO_2=https://images.unsplash.com/photo-1464349095431-e9a21285b5f3?w=800
VITE_PHOTO_3=https://images.unsplash.com/photo-1513151233558-d860c5398176?w=800

# Background Music URL (MP3, OGG, WAV supported)
VITE_SOUND_URL=https://assets.mixkit.co/active_storage/music/2869/2869-preview.mp3

# Sound effects enabled
VITE_SOUND_EFFECTS=true

# =====================================================
# ANIMATION & EFFECTS
# =====================================================

# Animation speed
# Options: "slow" | "moderate" | "fast"
VITE_ANIMATION_SPEED=moderate

# Particle effects count
VITE_PARTICLE_COUNT=25

# Animation intensity
# Options: "low" | "medium" | "high"
VITE_ANIMATION_INTENSITY=high

# Show skip intro button
VITE_SHOW_SKIP_BUTTON=true

# =====================================================
# ACCESSIBILITY
# =====================================================

# Reduce motion (for motion-sensitive users)
VITE_REDUCED_MOTION=false

# Text size scaling
# Options: "small" | "normal" | "large"
VITE_TEXT_SIZE=normal

# High contrast mode
VITE_HIGH_CONTRAST=false

# =====================================================
# TEMPLATE & THEME
# =====================================================

# Template theme
# Options: "romantic" | "fun" | "energetic" | "elegant" | "playful" | "nostalgic"
VITE_THEME=fun

# =====================================================
# AUDIO PREPARATION (Future Enhancement - v2.1+)
# =====================================================

# Song URL (for integration in v2.1)
VITE_SONG_URL=

# Voice message URL (recorded voice birthday message)
VITE_VOICE_MESSAGE_URL=

# =====================================================
# ADVANCED SETTINGS
# =====================================================

# Enable debug mode
VITE_DEBUG=false

# Analytics tracking ID
VITE_ANALYTICS_ID=

# Birthday date (ISO format)
VITE_BIRTHDAY_DATE=2026-04-24T00:00:00